{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "OpenOCD Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "serverpath": "${workspaceFolder}/xpacks/.bin/openocd.exe",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/nucleo-blink.elf",
            "device": "STM32F411RE",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "runToMain": true,
            "showDevDebugOutput": "raw"
        }
    ]
}