{
    "configurations": [
        {
            "name": "STM32",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/libs/STM32CubeF4/Drivers/CMSIS/Include",
                "${workspaceFolder}/libs/STM32CubeF4/Drivers/CMSIS/Device/ST/STM32F4xx/Include",
                "${workspaceFolder}/libs/STM32CubeF4/Drivers/STM32F4xx_HAL_Driver/Inc"
            ],
            "defines": [
                "STM32F411xE",           // Ваш конкретный чип
                "STM32F4",
                "STM32",
                "__STM32__",
                "DEBUG",
                "__weak=__attribute__((weak))",
                "__packed=__attribute__((__packed__))"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm",
            "compilerArgs": [
                "-mcpu=cortex-m4",
                "-mthumb",
                "-mfloat-abi=soft"
            ]
        }
    ],
    "version": 4
}